# Quote form email delivery (Brevo transactional HTTP API) — copy to .env.local.
# On submit, the form sends TWO emails: an internal notification to
# info@groutix.com, and a confirmation to the customer.
#
# Uses Brevo's HTTP API (not SMTP), so it is NOT limited by Brevo's
# "Authorized IPs" restriction — works from a dynamic local IP and serverless.
#
# 1. Sign up at https://www.brevo.com and verify info@groutix.com as a sender
#    (Senders → Add a sender → click the confirmation link — no DNS needed).
# 2. Go to "SMTP & API" → "API Keys" tab → Generate a new API key (starts with
#    "xkeysib-"). Copy it into BREVO_API_KEY below.
# 3. BREVO_FROM must be your verified sender address.
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxx
BREVO_FROM=info@groutix.com

# ─────────────────────────────────────────────────────────────
# Spam protection — Cloudflare Turnstile (free CAPTCHA)
# ─────────────────────────────────────────────────────────────
# 1. Go to https://dash.cloudflare.com → Turnstile → Add widget.
#    Add your domain(s) — include "localhost" for local testing.
# 2. Copy the two keys it gives you:
#    - Site Key   → public, goes in the browser (NEXT_PUBLIC_...)
#    - Secret Key → private, server-side only
# If these are left blank, the form still works but without bot protection.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─────────────────────────────────────────────────────────────
# Google reviews (Google Places API — New)
# ─────────────────────────────────────────────────────────────
# The testimonials sections pull live reviews from the GROUTIX Google Business
# Profile. If these are left blank, the site falls back to curated reviews.
#
# Setup:
# 1. Go to https://console.cloud.google.com/ and create (or pick) a project.
# 2. APIs & Services → Library → enable "Places API (New)".
# 3. APIs & Services → Credentials → Create credentials → API key.
#    Restrict it to the "Places API (New)" and (recommended) to your server IP.
# 4. Find your Place ID with https://developers.google.com/maps/documentation/places/web-service/place-id
#    (search your business name; copy the "Place ID" string, e.g. ChIJ...).
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
